#: C/calendar.page:20 C/entry.page:20 C/notification.page:14 C/progress.page:25
msgid "<cmd>--text</cmd>=<var>text</var>"
msgstr "<cmd>--text</cmd>=<var>текст</var>"

#. (itstool) path: item/p
#: C/calendar.page:21
msgid "Specifies the text that is displayed in the calendar dialog."
msgstr "Наводи текст који се приказује у прозорчету календара."

#. (itstool) path: item/title
#: C/calendar.page:25
msgid "<cmd>--day</cmd>=<var>day</var>"
msgstr "<cmd>--day</cmd>=<var>дан</var>"

#. (itstool) path: item/p
#: C/calendar.page:26
msgid ""
"Specifies the day that is selected in the calendar dialog. day must be a "
"number between 1 and 31 inclusive."
msgstr "Наводи дан који је изабран у прозорчету календара. дан мора бити број између 1 и 31 укључиво."

#. (itstool) path: item/title
#: C/calendar.page:30
msgid "<cmd>--month</cmd>=<var>month</var>"
msgstr "<cmd>--month</cmd>=<var>месец</var>"

#. (itstool) path: item/p
#: C/calendar.page:31
msgid ""
"Specifies the month that is selected in the calendar dialog. month must be a "
"number between 1 and 12 inclusive."
msgstr "Наводи месец који је изабран у прозорчету календара. месец мора бити број између 1 и 12 укључиво."

#. (itstool) path: item/title
#: C/calendar.page:35
msgid "<cmd>--year</cmd>=<var>year</var>"
msgstr "<cmd>--year</cmd>=<var>година</var>"

