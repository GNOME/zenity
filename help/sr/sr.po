#, no-wrap
msgid ""
"\n"
"#!/bin/sh\n"
"\n"
"\n"
"if zenity --calendar \\\n"
"--title=\"Select a Date\" \\\n"
"--text=\"Click on a date to select that date.\" \\\n"
"--day=10 --month=8 --year=2004\n"
"  then echo $?\n"
"  else echo \"No date selected\"\n"
"fi\n"
msgstr ""
"\n"
"#!/bin/sh\n"
"\n"
"\n"
"if zenity --calendar \\\n"
"--title=\"Изаберите датум\" \\\n"
"--text=\"Кликните на датум да га изаберете.\" \\\n"
"--day=10 --month=8 --year=2004\n"
"  then echo $?\n"
"  else echo \"Није изабран датум\"\n"
"fi\n"

